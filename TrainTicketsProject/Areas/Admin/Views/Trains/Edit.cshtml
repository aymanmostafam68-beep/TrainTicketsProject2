@model TrainEditVM

<main>
    <div class="container-fluid py-4">
        <!-- Breadcrumb & Title Section -->
        <div class="row align-items-center justify-content-between g-3 mb-4">
            <div class="col-auto">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/admin/home">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index">Trains List</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit Train</li>
                    </ol>
                </nav>
                <h3 class="fw-bold text-900 mt-2">✏️ Edit Train: <span class="text-primary">@Model.train.TrainName</span></h3>
            </div>
            <div class="col-auto">
                <a asp-action="Index" class="btn btn-falcon-default btn-sm">
                    <span class="fas fa-chevron-left me-1"></span> Back to List
                </a>
            </div>
        </div>

        <div class="row g-3">
            <!-- Left Side: Train Configuration (8/12) -->
            <div class="col-lg-8">
                <div class="card shadow-none border mb-3">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Train Details</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Edit" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="train.TrainId" />

                            <!-- Train Name -->
                            <div class="col-md-12">
                                <label class="form-label text-900 fw-semi-bold" asp-for="train.TrainName">Train Name / Number</label>
                                <input asp-for="train.TrainName" class="form-control shadow-none" placeholder="e.g. Express 901" />
                                <span asp-validation-for="train.TrainName" class="text-danger fs--1"></span>
                            </div>

                            <!-- Route Selection -->
                            <div class="col-md-8">
                                <label class="form-label text-900 fw-semi-bold" asp-for="train.RouteId">Assigned Route</label>
                                <select asp-for="train.RouteId" class="form-select shadow-none js-choice"
                                        asp-items="@(new SelectList(Model.Routes, "RouteId", "RouteName"))">
                                    <option value="">-- Select Route --</option>
                                </select>
                                <div class="form-text fs--2">Assign this train to a specific operational route.</div>
                                <span asp-validation-for="train.RouteId" class="text-danger fs--1"></span>
                            </div>

                            <!-- Active Status -->
                            <div class="col-md-4">
                                <label class="form-label text-900 fw-semi-bold">Operational Status</label>
                                <div class="form-check form-switch mt-1">
                                    <input asp-for="train.IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch" />
                                    <label class="form-check-label fw-normal" for="isActiveSwitch">Is Train Active?</label>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="col-12 mt-4 border-top pt-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <a asp-action="Index" class="btn btn-falcon-default btn-sm me-2">
                                        <span class="fas fa-times me-1"></span> Cancel
                                    </a>
                                </div>
                                <button type="submit" class="btn btn-primary px-5">
                                    <span class="fas fa-save me-1"></span> Update Train
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Side: Meta Info Card (4/12) -->
            <div class="col-lg-4">
                <div class="card shadow-none border bg-light h-100">
                    <div class="card-header bg-transparent border-bottom">
                        <h6 class="mb-0 d-flex align-items-center">
                            <span class="fas fa-info-circle me-2 text-primary"></span>Record Information
                        </h6>
                    </div>
                    <div class="card-body fs--1">
                        <!-- Created Info -->
                        <div class="mb-3">
                            <label class="text-600 fw-bold mb-1">Created Date</label>
                            <div class="p-2 bg-white rounded border">
                                <span class="text-900">@Model.CreatedAtInfo</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="text-600 fw-bold mb-1">Created By</label>
                            <div class="p-2 bg-white rounded border d-flex align-items-center">
                                <span class="fas fa-user fs--2 me-2 text-400"></span>
                                <span class="text-900">@Model.createdUserName</span>
                            </div>
                        </div>

                        <hr class="text-300" />

                        <!-- Updated Info -->
                        <div class="mb-3">
                            <label class="text-600 fw-bold mb-1 text-primary text-uppercase">Last Update</label>
                            <div class="p-2 bg-white rounded border">
                                <span class="text-900">@Model.UpdatedAtInfo</span>
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="text-600 fw-bold mb-1">Updated By</label>
                            <div class="p-2 bg-white rounded border d-flex align-items-center">
                                <span class="fas fa-user-edit fs--2 me-2 text-400"></span>
                                <span class="text-900">@(Model.updatedUserName ?? "N/A")</span>
                            </div>
                        </div>

                        <div class="mt-4 p-3 bg-white rounded-2 border">
                            <h6 class="fs--2 text-600 fw-bold text-uppercase italic">System Note</h6>
                            <p class="mb-0 text-muted small">Updating the route will affect all future schedules associated with this train ID.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}