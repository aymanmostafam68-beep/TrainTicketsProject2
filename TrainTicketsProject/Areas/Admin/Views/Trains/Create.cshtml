@model TrainCreateVM

<main>
    <div class="container-fluid py-4">
        <!-- Breadcrumb & Title Section -->
        <div class="row align-items-center justify-content-between g-3 mb-4">
            <div class="col-auto">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/admin/home">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index">Trains</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Add New Train</li>
                    </ol>
                </nav>
                <h3 class="fw-bold text-900 mt-2">🚆 Add New Train</h3>
            </div>
            <div class="col-auto">
                <a asp-action="Index" class="btn btn-falcon-default btn-sm">
                    <span class="fas fa-chevron-left me-1"></span> Back to List
                </a>
            </div>
        </div>

        <div class="row g-3">
            <!-- Left Side: Main Form -->
            <div class="col-lg-8">
                <div class="card shadow-none border">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">General Train Information</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Create" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger fs--1"></div>

                            <!-- Train Name -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="train.TrainName">Train Name <span class="text-danger">*</span></label>
                                <input class="form-control shadow-none" asp-for="train.TrainName" placeholder="e.g. Express 501" required>
                                <span class="text-danger fs--1" asp-validation-for="train.TrainName"></span>
                            </div>

                            <!-- Train Code -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="train.TrainCode">Train Code <span class="text-danger">*</span></label>
                                <input class="form-control shadow-none fw-bold" asp-for="train.TrainCode" placeholder="TRN-001" required>
                                <span class="text-danger fs--1" asp-validation-for="train.TrainCode"></span>
                            </div>

                            <!-- Route Selection -->
                            <div class="col-md-12">
                                <label class="form-label text-900 fw-semi-bold" asp-for="train.RouteId">Assigned Route <span class="text-danger">*</span></label>
                                <select class="form-select shadow-none js-choice" asp-for="train.RouteId"
                                        asp-items="@(new SelectList(Model.Routes, "RouteId", "RouteName"))">
                                    <option value="">-- Select a Route --</option>
                                </select>
                                <div class="form-text fs--1 text-muted">Assigning a route is mandatory for scheduling.</div>
                                <span class="text-danger fs--1" asp-validation-for="train.RouteId"></span>
                            </div>

                            <!-- Form Actions -->
                            <div class="col-12 mt-4 border-top pt-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <a asp-action="Index" class="btn btn-falcon-default btn-sm me-2">
                                        <span class="fas fa-times me-1"></span> Cancel
                                    </a>
                                    <button type="reset" class="btn btn-link text-danger btn-sm p-0 shadow-none">Reset Form</button>
                                </div>
                                <button type="submit" class="btn btn-primary px-5">
                                    <span class="fas fa-save me-1"></span> Save Train
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Side: Info & Preview -->
            <div class="col-lg-4">
                <div class="card shadow-none border bg-light h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="fas fa-info-circle text-primary fs-2 me-2"></span>
                            <h6 class="mb-0">Train Configuration Info</h6>
                        </div>
                        <p class="fs--1 text-600">Ensure the <strong>Train Code</strong> is unique across the fleet. This code will be used for tracking and maintenance logs.</p>
                        <hr>
                        <div class="bg-white p-3 rounded-3 border mb-3">
                            <h6 class="fs--1 fw-bold">Live Preview</h6>
                            <div class="text-uppercase fw-semi-bold fs--2 text-500">Train Identity:</div>
                            <div class="fs-2 fw-bold text-primary mb-1" id="name-preview">New Train</div>
                            <div class="badge badge-soft-info fs--2" id="code-preview">NO-CODE</div>
                        </div>

                        <div class="alert alert-warning border-0 d-flex align-items-center mb-0" role="alert">
                            <div class="bg-warning me-3 icon-item"><span class="fas fa-exclamation-triangle text-white fs-1"></span></div>
                            <p class="mb-0 flex-1 fs--1">Changing the <strong>Route</strong> after creation may affect existing trip schedules.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Simple live preview for the side card[cite: 2]
        document.getElementById('train_TrainName').addEventListener('input', function(e) {
            document.getElementById('name-preview').innerText = e.target.value || 'New Train';
        });

        document.getElementById('train_TrainCode').addEventListener('input', function(e) {
            document.getElementById('code-preview').innerText = e.target.value || 'NO-CODE';
        });
    </script>
}