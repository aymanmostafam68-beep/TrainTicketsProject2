@using TrainTicketsProject.ViewModels;
@model TrainTicketsProject.ViewModels.RouteVM

<main>
    <div class="container-fluid py-4">
        <!-- Breadcrumb & Title -->
        <div class="row align-items-center justify-content-between g-3 mb-4">
            <div class="col-auto">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/admin/home">Dashboard</a></li>
                        <li class="breadcrumb-item"><a href="/admin/section">Routes</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Create Route</li>
                    </ol>
                </nav>
                <h3 class="fw-bold text-900 mt-2">Create New Route</h3>
            </div>
            <div class="col-auto">
                <a href="/admin/section" class="btn btn-falcon-default btn-sm">
                    <span class="fas fa-chevron-left me-1"></span> Back to List
                </a>
            </div>
        </div>

        <div class="row g-3">
            <!-- Left Side: Main Form -->
            <div class="col-lg-8">
                <div class="card shadow-none border">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Route Configuration</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" enctype="multipart/form-data" class="row g-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger fs--1"></div>

                            <!-- Route Name -->
                            <div class="col-md-7">
                                <label class="form-label text-900 fw-semi-bold" asp-for="RouteName">Route Name <span class="text-danger">*</span></label>
                                <input class="form-control shadow-none" asp-for="RouteName" placeholder="e.g. Cairo - Alexandria Express" required>
                                <span class="text-danger fs--1" asp-validation-for="RouteName"></span>
                            </div>

                            <!-- Route Code -->
                            <div class="col-md-5">
                                <label class="form-label text-900 fw-semi-bold" asp-for="Code">System Code <span class="text-danger">*</span></label>
                                <input class="form-control shadow-none fw-bold" asp-for="Code" placeholder="UPPEREGYPT_1" required>
                                <span class="text-danger fs--1" asp-validation-for="Code"></span>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label class="form-label text-900 fw-semi-bold" asp-for="Description">Description</label>
                                <textarea class="form-control shadow-none" asp-for="Description" rows="2" placeholder="Route details and notes..."></textarea>
                                <span class="text-danger fs--1" asp-validation-for="Description"></span>
                            </div>

                            <!-- Start & End Points -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="StartPoint">Start Point <span class="text-danger">*</span></label>
                                <select class="form-select shadow-none js-choice" asp-for="StartPoint" asp-items="@(new SelectList(Model.AvailableStations, "StationCode", "StationName"))">
                                    <option value="">-- Select Start --</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="StartPoint"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="EndPoint">End Point <span class="text-danger">*</span></label>
                                <select class="form-select shadow-none js-choice" asp-for="EndPoint" asp-items="@(new SelectList(Model.AvailableStations, "StationCode", "StationName"))">
                                    <option value="">-- Select End --</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="EndPoint"></span>
                            </div>

                            <!-- Intermediate Stations Table -->
                            <div class="col-12 mt-4">
                                <label class="form-label text-900 fw-bold fs-0">Intermediate Stations & Distances</label>
                                <div class="table-responsive scrollbar">
                                    <table class="table table-sm table-bordered fs--1 mb-0">
                                        <thead class="bg-200 text-900">
                                            <tr>
                                                <th class="white-space-nowrap" style="width: 50px;">Select</th>
                                                <th>Station Name</th>
                                                <th style="width: 150px;">Distance (km)</th>
                                            </tr>
                                        </thead>
                                        <tbody class="list">
                                            @for (int i = 0; i < Model.AvailableStations.Count; i++)
                                            {
                                                <tr>
                                                    <td class="align-middle text-center">
                                                        <input type="checkbox" asp-for="@Model.AvailableStations[i].IsSelected" class="form-check-input mt-0" />
                                                        <input type="hidden" asp-for="@Model.AvailableStations[i].StationCode" />
                                                        <input type="hidden" asp-for="@Model.AvailableStations[i].StationName" />
                                                    </td>
                                                    <td class="align-middle fw-semi-bold text-900">@Model.AvailableStations[i].StationName</td>
                                                    <td class="align-middle">
                                                        <div class="input-group input-group-sm">
                                                            <input type="number" asp-for="@Model.AvailableStations[i].DistanceFromStart" class="form-control shadow-none" step="0.1" />
                                                            <span class="input-group-text bg-light">km</span>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="col-md-6 mt-3">
                                <label class="form-label text-900 fw-semi-bold">Status</label>
                                <select class="form-select shadow-none" name="status">
                                    <option selected value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>

                            <!-- Form Actions -->
                            <div class="col-12 mt-4 border-top pt-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <a href="/admin/section" class="btn btn-falcon-default btn-sm me-2">
                                        <span class="fas fa-times me-1"></span> Cancel
                                    </a>
                                    <button type="reset" class="btn btn-link text-danger btn-sm p-0 shadow-none">Reset Form</button>
                                </div>
                                <button type="submit" class="btn btn-primary px-5">
                                    <span class="fas fa-save me-1"></span> Create Route
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Side: Info & Preview -->
            <div class="col-lg-4">
                <div class="card shadow-none border bg-light h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="fas fa-route text-primary fs-2 me-2"></span>
                            <h6 class="mb-0">Route Logic</h6>
                        </div>
                        <p class="fs--1 text-600">Ensure the <strong>System Code</strong> is unique. It should follow the <code>REGION_NUMBER</code> format (e.g., DELTA_01)[cite: 2].</p>
                        <hr>
                        <div class="bg-white p-3 rounded-3 border mb-3">
                            <h6 class="fs--1 fw-bold">Live Summary</h6>
                            <div class="text-uppercase fw-semi-bold fs--2 text-500">Route Identity:</div>
                            <div class="fs-1 fw-bold text-primary mb-2" id="name-preview">New Route</div>
                            <div class="text-uppercase fw-semi-bold fs--2 text-500">Code:</div>
                            <div class="fs--1 fw-bold" id="code-preview">---</div>
                        </div>
                        <div class="alert alert-info border-0 d-flex align-items-center" role="alert">
                            <div class="bg-info me-3 icon-item"><span class="fas fa-info-circle text-white fs-1"></span></div>
                            <p class="mb-0 flex-1 fs--1">Distance should be measured from the <strong>Start Point (0 km)</strong>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_notificationPartial" />
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Live Preview Logic
        document.getElementById('RouteName').addEventListener('input', function(e) {
            document.getElementById('name-preview').innerText = e.target.value || 'New Route';
        });

        document.getElementById('Code').addEventListener('input', function(e) {
            document.getElementById('code-preview').innerText = e.target.value || '---';
        });
    </script>
}