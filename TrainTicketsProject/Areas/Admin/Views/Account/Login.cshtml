@model IdentityVM
@{
    Layout = "_Layout";
}


<!DOCTYPE html>
<html data-bs-theme="dark" lang="en-US" dir="ltr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" asp-append-version="true" />

    <!-- ===============================================-->
    <!--    Document Title-->
    <!-- ===============================================-->
    <title>TrainTickets | Dashboard &amp; Web App Template</title>


    <!-- ===============================================-->
    <!--    Favicons-->
    <!-- ===============================================-->
    <link rel="apple-touch-icon" sizes="180x180" href="../../Identity/assets/img/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="../../Identity/assets/img/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="../../Identity/assets/img/favicons/favicon-16x16.png">
    <link rel="shortcut icon" type="image/x-icon" href="../../Identity/assets/img/favicons/favicon.ico">
    <link rel="manifest" href="../../Identity/assets/img/favicons/manifest.json">
    <meta name="msapplication-TileImage" content="../../Identity/assets/img/favicons/mstile-150x150.png">
    <meta name="theme-color" content="#ffffff">
    <script src="../../Identity/assets/js/config.js"></script>
    <script src="~/vendors/simplebar/simplebar.min.js"></script>


    <!-- ===============================================-->
    <!--    Stylesheets-->
    <!-- ===============================================-->
    <link rel="preconnect" href="https://fonts.gstatic.com">
@*     <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,600,700%7cPoppins:300,400,500,600,700,800,900&amp;display=swap" rel="stylesheet">
 *@    <link href="~/vendors/simplebar/simplebar.min.css" rel="stylesheet">
    <link href="~/assets/css/theme-rtl.css" rel="stylesheet" id="style-rtl">
    <link href="~/assets/css/theme.css" rel="stylesheet" id="style-default">
    <link href="~/assets/css/user-rtl.css" rel="stylesheet" id="user-style-rtl">
    <link href="~/assets/css/user.css" rel="stylesheet" id="user-style-default">
  
    </script>
</head>


<body>

    <!-- ===============================================-->
    <!--    Main Content-->
    <!-- ===============================================-->
    <main class="main" id="top">
        <div class="container-fluid">
            <div class="row min-vh-100 flex-center g-0">
                <div class="col-lg-10 col-xxl-8 py-3 position-relative">
                    <img class="bg-auth-circle-shape" src="../../Identity/assets/img/icons/spot-illustrations/bg-shape.png" alt="" width="250"><img class="bg-auth-circle-shape-2" src="../../Identity/assets/img/icons/spot-illustrations/shape-1.png" alt="" width="150">
                    <div class="card overflow-hidden z-1">
                        <div class="card-body p-0">
                            <div class="row g-0 h-100">
                                <div class="col-md-5 text-center bg-card-gradient d-flex flex-column justify-content-between">

                                    <!-- MIDDLE (Train System) -->
                                    <div class="px-4 p-4 text-center">
                                        <a class="text-primary mb-2 font-sans-serif fs-5 d-inline-block fw-bolder text-decoration-none"
                                           href="/Identity/Account/index">
                                            Train Tickets System
                                        </a>
                                    </div>
                                    <!-- TOP (image) -->
                                    <div class="position-relative p-4 pt-md-5 pb-md-8" data-bs-theme="light">
                                        <div class="bg-holder bg-auth-card-shape"
                                             style="background-image:url(../../Identity/assets/img/icons/spot-illustrations/train.png); background-position: center 10%">
                                        </div>
                                    </div>



                                    <!-- BOTTOM (Register) -->
                                    <p class="text-danger fw-bold fs-4 text-uppercase">
                                        <i class="bi bi-gear-fill me-2"></i>
                                        Admin Dashboard
                                    </p>

                                </div>
                                <div class="col-md-7 d-flex flex-center">
                                    <div class="p-4 p-md-5 flex-grow-1">
                                        <div class="row flex-between-center">
                                            <div class="col-auto">
                                                <h3>Account Login</h3>
                                            </div>
                                        </div>
                                        <form method="post" asp-action="Login">

                                            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                                            <div class="mb-3">
                                                <label asp-for="UsernameOrEmail" class="form-label" for="card-email">Email address</label>
                                                <input asp-for="UsernameOrEmail" class="form-control" name="UsernameOrEmail" id="card-email" type="email" />
                                                <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>

                                            </div>
                                            <div class="mb-3">
                                                <label asp-for="Password" class="form-label" for="card-password">Password</label>
                                                <input asp-for="Password" class="form-control" name="Password" id="card-password" type="password" />
                                                <span asp-validation-for="Password" class="text-danger small"></span>
                                            </div>
                                            <div class="row flex-between-center">
                                                <div class="col-auto">
                                                    <div class="form-check mb-0">
                                                        <input class="form-check-input" type="checkbox" id="card-checkbox" checked="checked" />
                                                        <label class="form-check-label mb-0" for="card-checkbox">Remember me</label>
                                                    </div>
                                                </div>
                                                <div class="col-auto"><a class="fs-10" href="/Identity/Account/ForgotPassword">Forgot Password?</a></div>
                                            </div>
                                            <div class="mb-3">
                                                <button class="btn btn-primary d-block w-100 mt-3" type="submit" name="submit">Log in</button>
                                            </div>
                                        </form>
                                                                     
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <!-- ===============================================-->
    <!--     <!-- Bootstrap JS -->
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- ===============================================-->
    @section Scripts
    {

        <partial name="_ToastreScriptPartial" />
        <partial name="_ValidationScriptsPartial" />

    }


    <!-- ===============================================-->
    <!--    JavaScripts-->
    <!-- ===============================================-->
    <script src="../../../vendors/popper/popper.min.js"></script>
    <script src="../../../vendors/bootstrap/bootstrap.min.js"></script>
    <script src="../../../vendors/anchorjs/anchor.min.js"></script>
    <script src="../../../vendors/is/is.min.js"></script>
    <script src="../../../vendors/fontawesome/all.min.js"></script>
    <script src="../../../vendors/lodash/lodash.min.js"></script>
    <script src="../../../vendors/list.js/list.min.js"></script>
    <script src="../../../assets/js/theme.js"></script>

</body>

</html>