@using System.Security.Claims

<!DOCTYPE html>
<html lang="en-US" dir="ltr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Station Admin | Falcon</title>

    <script>
        // Dark Mode
        var isDark = JSON.parse(localStorage.getItem('isDark'));
        if (isDark) {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
        } else {
            document.documentElement.setAttribute('data-bs-theme', 'light');
        }
    </script>

    <!-- Falcon Stylesheets -->
    <link rel="stylesheet" href="~/vendors/simplebar/simplebar.min.css">
    <link rel="stylesheet" href="~/assets/css/theme.min.css" id="style-default">
    <link rel="stylesheet" href="~/assets/css/user.min.css" id="user-style-default">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <script src="~/assets/js/config.js"></script>
    <script src="~/vendors/simplebar/simplebar.min.js"></script>

    <style>
        /*
                 * FIX 1 — السايد بار يبدأ من أعلى الشاشة بالكامل
                 */
        .navbar-vertical.navbar-expand-xl {
            top: 0 !important;
        }

        /*
                 * FIX 2 — التوب بار sticky جوه الـ content (مش fixed على كل الشاشة)
                 * ده بيخليه يبدأ من بعد السايد بار ولا يغطي عليه
                 */
        .navbar-top {
            position: sticky !important;
            top: 0 !important;
            z-index: 1020;
        }

        /*
                 * FIX 3 — مسافة علوية تحت التوب بار قبل المحتوى
                 */
        .content > .page-body {
            padding-top: 1.5rem;
        }

        .navbar-vertical .navbar-brand {
            width: 100%;
        }

            .navbar-vertical .navbar-brand span {
                white-space: normal;
            }
    </style>
</head>

<body>

    @{
        var fullName = User.FindFirst("FullName")?.Value;
        var jobName = User.FindFirst("JobName")?.Value;
        var code = User.FindFirst("Code")?.Value;
        var email = User.FindFirst("Email")?.Value;
        var userName = User.FindFirst(ClaimTypes.Name)?.Value.Replace(".", " ") ?? User.FindFirst(ClaimTypes.Name)?.Value;
    }


    <main class="main" id="top">

        <!--
            FIX 4 — container-fluid بدل container
            عشان الـ layout ياخد عرض الشاشة كاملاً بدون margins جانبية فاضية
        -->
        <div class="container-fluid" data-layout="container">

            <!-- ============================================================
                 السايد بار — يجي أولاً دائماً في Falcon
                 "Admin Panel" هنا فقط، مش في التوب بار
            ============================================================ -->
            <nav class="navbar navbar-light navbar-vertical navbar-expand-xl">

                <div class="d-flex align-items-center">
                    <div class="toggle-icon-wrapper">
                        <!--
                            FIX 5 — زر hamburger السايد بار
                            Falcon بيستمع لـ class="navbar-vertical-toggle" في theme.js
                            وبيعمل toggle للسايد بار تلقائياً
                        -->
                        <button class="btn navbar-toggler-humburger-icon navbar-vertical-toggle"
                                data-bs-toggle="tooltip"
                                data-bs-placement="left"
                                title="Toggle Navigation">
                            <span class="navbar-toggle-icon"><span class="toggle-line"></span></span>
                        </button>
                    </div>
                    <a class="navbar-brand" href="/">
                        <div class="d-flex align-items-center py-3">
                           
                            <span class="fas fa-train text-primary me-3 fs-4"></span>
                            <span class="font-sans-serif fw-bolder fs-6 text-dark">
                                Admin Panel
                            </span>
                        </div>
                    </a>
                </div>

                <div class="collapse navbar-collapse" id="navbarVerticalCollapse">
                    <div class="navbar-vertical-content scrollbar">
                        <ul class="navbar-nav flex-column mb-3" id="navbarVerticalNav">

                            <!-- CORE -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Core</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>
                                <a class="nav-link" href="/Admin/Home/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-primary"><span class="fas fa-chart-pie"></span></span>
                                        <span class="nav-link-text ps-1">Dashboard</span>
                                    </div>
                                </a>
                            </li>

                            <!-- MANAGEMENT -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Management</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>

                                <!-- Station Management -->
                                <a class="nav-link dropdown-indicator" href="#collapseStation"
                                   data-bs-toggle="collapse" aria-expanded="false">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-info"><span class="fas fa-book-open"></span></span>
                                        <span class="nav-link-text ps-1">Station Management</span>
                                    </div>
                                </a>
                                <ul class="nav collapse" id="collapseStation">
                                    <li class="nav-item"><a class="nav-link" href="/Admin/GeneralSetting/Index">General Setting </a></li>

                                    <li class="nav-item"><a class="nav-link" href="/Admin/Station/Index">Stations Setup</a></li>
                                </ul>

                                <!-- User Management -->
                                <a class="nav-link dropdown-indicator" href="#collapseUserMgmt"
                                   data-bs-toggle="collapse" aria-expanded="false">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-success"><span class="fas fa-user-cog"></span></span>
                                        <span class="nav-link-text ps-1">User Management</span>
                                    </div>
                                </a>
                                <ul class="nav collapse" id="collapseUserMgmt">
                                    <li class="nav-item"><a class="nav-link" href="/Admin/User/Index">All Users</a></li>
                                </ul>

                                <!-- Trains Management -->
                                <a class="nav-link dropdown-indicator" href="#collapseTrains"
                                   data-bs-toggle="collapse" aria-expanded="false">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-warning"><span class="fas fa-train"></span></span>
                                        <span class="nav-link-text ps-1">Trains Management</span>
                                    </div>
                                </a>
                                <ul class="nav collapse" id="collapseTrains">
                                    <li class="nav-item"><a class="nav-link" href="/Admin/Route/Index">Routes</a></li>
                                    <li class="nav-item"><a class="nav-link" href="/Admin/Trains/Index">Trains</a></li>
                                    <li class="nav-item"><a class="nav-link" href="/Admin/Carriage/Index">Carriages</a></li>
                                    <li class="nav-item"><a class="nav-link" href="/Admin/CarriageClass/Index">Carriages Class</a></li>
                                    <li class="nav-item"><a class="nav-link" href="/Admin/CarraiageSeat/Index">Carriage Seats</a></li>
                               
                                </ul>

                                <!-- Trips & Schedules -->
                                <a class="nav-link dropdown-indicator" href="#collapseTrips"
                                   data-bs-toggle="collapse" aria-expanded="false">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-danger"><span class="fas fa-calendar-alt"></span></span>
                                        <span class="nav-link-text ps-1">Trips &amp; Schedules</span>
                                    </div>
                                </a>
                                <ul class="nav collapse" id="collapseTrips">
                                    <li class="nav-item"><a class="nav-link" href="/Admin/Trip/Index">Trips</a></li>
                                    <li class="nav-item"><a class="nav-link" href="/Admin/TripSchedules/Index">Trips Schedules</a></li>
                                </ul>

                                <!-- Trains Report -->
                                <a class="nav-link dropdown-indicator" href="#collapseReports"
                                   data-bs-toggle="collapse" aria-expanded="false">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-secondary"><span class="fas fa-file-invoice"></span></span>
                                        <span class="nav-link-text ps-1">Trains Report</span>
                                    </div>
                                </a>
                                <ul class="nav collapse" id="collapseReports">
                                    <li class="nav-item"><a class="nav-link" href="/Admin/Report/Index">Trains Info</a></li>
                                </ul>
                            </li>

                            <!-- ADDONS -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Site Mananement</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>
                                <a class="nav-link" href="/Admin/GeneralSetting/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon text-info"><span class="fas fa-chart-bar"></span></span>
                                        <span class="nav-link-text ps-1">Site Settings</span>

                                    </div>
                                </a>
                               
                            </li>

                        </ul>
                    </div>
                </div>
            </nav>
            <!-- نهاية السايد بار -->
            <!-- ============================================================
                 منطقة الـ content — التوب بار + المحتوى + الفوتر
            ============================================================ -->
            <div class="content">

                <!-- التوب بار -->
                <nav class="navbar navbar-light navbar-glass navbar-top navbar-expand shadow-sm mb-3">

                    <!--
                        زر الـ hamburger في التوب بار
                        بيشتغل على الموبايل لفتح/غلق السايد بار
                    -->
                    <button class="btn navbar-toggler-humburger-icon navbar-toggler me-1 me-sm-3"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarVerticalCollapse"
                            aria-controls="navbarVerticalCollapse"
                            aria-expanded="false">
                        <span class="navbar-toggle-icon"><span class="toggle-line"></span></span>
                    </button>

                    <!-- Dark Mode Toggle -->
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item px-2">
                            <div class="theme-control-toggle fa-icon-wait">
                                <input class="form-check-input ms-0 theme-control-toggle-input"
                                       id="themeControlToggle" type="checkbox"
                                       data-theme-control="theme" value="dark" />
                                <label class="mb-0 theme-control-toggle-label theme-control-toggle-light"
                                       for="themeControlToggle"
                                       data-bs-toggle="tooltip" data-bs-placement="left"
                                       title="Switch to dark theme">
                                    <span class="fas fa-sun fs-0"></span>
                                </label>
                                <label class="mb-0 theme-control-toggle-label theme-control-toggle-dark"
                                       for="themeControlToggle"
                                       data-bs-toggle="tooltip" data-bs-placement="left"
                                       title="Switch to light theme">
                                    <span class="fas fa-moon fs-0"></span>
                                </label>
                            </div>
                        </li>
                    </ul>

                    <!-- التاريخ + User Dropdown -->
                    <ul class="navbar-nav navbar-nav-icons ms-auto flex-row align-items-center">
                        <li class="nav-item d-none d-md-block me-3 text-600 fw-semi-bold">
                            @DateTime.Now.ToString("dd MMM yyyy")
                        </li>

                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link pe-0 ps-2" id="navbarDropdownUser" role="button"
                                   data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="d-none d-lg-block text-end">
                                            <h6 class="mb-0 lh-1 text-900">@User.Identity.Name</h6>
                                            <p class="fs--2 mb-0 text-500">Super Admin</p>
                                        </div>
                                        <div class="avatar avatar-l">
                                            <div class="avatar-name rounded-circle bg-soft-primary text-primary">
                                                <span>@((User.Identity.Name ?? "U").Substring(0, 1).ToUpper())</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                                <div class="dropdown-menu dropdown-caret dropdown-menu-end py-0"
                                     aria-labelledby="navbarDropdownUser">
                                    <div class="bg-white dark__bg-1000 rounded-2 py-2">
                                        <div class="dropdown-item fw-bold text-warning">
                                            Hi, @User.Identity.Name
                                        </div>
                                        <div class="dropdown-divider"></div>
                                        <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout">
                                            <button type="submit" class="dropdown-item text-danger fw-bold">
                                                <span class="fas fa-sign-out-alt me-1"></span> Logout
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </nav>
                <!-- نهاية التوب بار -->
                <!-- محتوى الصفحة -->
                <div class="page-body">
                    @RenderBody()
                </div>

                <footer class="footer">
                    <div class="row g-0 justify-content-between fs--1 mt-4 mb-3">
                        <div class="col-12 col-sm-auto text-center">
                            <p class="mb-0 text-600">Station Management &copy; 2026</p>
                        </div>
                    </div>
                </footer>

            </div>
            <!-- نهاية الـ content -->

        </div>
    </main>

    <!-- Scripts — الترتيب مهم -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/vendors/popper/popper.min.js"></script>
    <script src="~/vendors/bootstrap/bootstrap.min.js"></script>
    <script src="~/vendors/fontawesome/all.min.js"></script>
    <script src="~/vendors/lodash/lodash.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/vendors/echarts/echarts.min.js"></script>
    <!-- theme.js لازم يجي آخر عشان يشتغل صح -->
    <script src="~/assets/js/theme.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
