@using TrainTicketsProject.Models.ViewsModel.CarriageClassVMs
@model CarriageClassCreateVM

<main>
    <div class="container-fluid py-4">
        <!-- Breadcrumb & Title Section -->
        <div class="row align-items-center justify-content-between g-3 mb-4">
            <div class="col-auto">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/admin/home">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index">Carriage Classes</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Create Class</li>
                    </ol>
                </nav>
                <h3 class="fw-bold text-900 mt-2">✨ Create New Carriage Class</h3>
            </div>
            <div class="col-auto">
                <a asp-action="Index" class="btn btn-falcon-default btn-sm">
                    <span class="fas fa-chevron-left me-1"></span> Back to List
                </a>
            </div>
        </div>

        <div class="row g-3">
            <!-- Left Side: Main Form -->
            <div class="col-lg-8">
                <div class="card shadow-none border">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Class Configuration & Pricing</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-area="Admin" asp-controller="CarriageClass" asp-action="Create" enctype="multipart/form-data" class="row g-3">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger fs--1"></div>

                            <!-- Class Name -->
                            <div class="col-md-7">
                                <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.Name">Class Name <span class="text-danger">*</span></label>
                                <input class="form-control shadow-none" asp-for="CarriageClass.Name" placeholder="e.g. VIP, First Class, Economy" required>
                                <span class="text-danger fs--1" asp-validation-for="CarriageClass.Name"></span>
                            </div>

                            <!-- Increase Percentage -->
                            <div class="col-md-5">
                                <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.IncreasePercentage">Price Increase (%) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input class="form-control shadow-none" asp-for="CarriageClass.IncreasePercentage" type="number" step="0.01" placeholder="0.00">
                                    <span class="input-group-text bg-200">%</span>
                                </div>
                                <span class="text-danger fs--1" asp-validation-for="CarriageClass.IncreasePercentage"></span>
                            </div>

                            <hr class="my-4" />
                            <h6 class="mb-3 fw-bold">Available Amenities</h6>

                            <!-- Food Option -->
                            <div class="col-md-4">
                                <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.Hasfood">Catering Service</label>
                                <select class="form-select shadow-none" asp-for="CarriageClass.Hasfood">
                                    <option value="" selected disabled>Select...</option>
                                    <option value="true">Included</option>
                                    <option value="false">Not Available</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="CarriageClass.Hasfood"></span>
                            </div>

                            <!-- Wifi Option -->
                            <div class="col-md-4">
                                <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.HasWifi">Internet / WiFi</label>
                                <select class="form-select shadow-none" asp-for="CarriageClass.HasWifi">
                                    <option value="" selected disabled>Select...</option>
                                    <option value="true">Available</option>
                                    <option value="false">Not Available</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="CarriageClass.HasWifi"></span>
                            </div>

                            <!-- AC Option -->
                            <div class="col-md-4">
                                <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.HasAirConditioning">Air Conditioning</label>
                                <select class="form-select shadow-none" asp-for="CarriageClass.HasAirConditioning">
                                    <option value="" selected disabled>Select...</option>
                                    <option value="true">Equipped</option>
                                    <option value="false">Standard Ventilated</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="CarriageClass.HasAirConditioning"></span>
                            </div>

                            <!-- Form Actions -->
                            <div class="col-12 mt-4 border-top pt-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <a asp-action="Index" class="btn btn-falcon-default btn-sm me-2">
                                        <span class="fas fa-times me-1"></span> Cancel
                                    </a>
                                </div>
                                <button type="submit" class="btn btn-primary px-5">
                                    <span class="fas fa-plus-circle me-1"></span> Create Class
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Side: Preview & Metrics -->
            <div class="col-lg-4">
                <div class="card shadow-none border bg-light h-100">
                    <div class="card-body">
                        <h6 class="mb-3">Visual Preview</h6>
                        <div class="bg-white p-3 rounded-3 border mb-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="text-primary mb-0" id="preview-name">New Class</h4>
                                <span class="badge badge-soft-success fs--2" id="preview-percentage">+0% Fee</span>
                            </div>

                            <div class="mt-3">
                                <p class="text-500 fs--2 fw-bold text-uppercase mb-2">Features Included:</p>
                                <div class="d-flex gap-2">
                                    <span id="icon-food" class="text-300 fas fa-utensils fs-1" title="Food"></span>
                                    <span id="icon-wifi" class="text-300 fas fa-wifi fs-1" title="WiFi"></span>
                                    <span id="icon-ac" class="text-300 fas fa-snowflake fs-1" title="AC"></span>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning border-0 fs--1" role="alert">
                            <span class="fas fa-exclamation-circle me-2"></span>
                            <strong>Note:</strong> The percentage increase is added to the base route price for all tickets in this class.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ToastreScriptPartial" />
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Update Preview Live
        const updatePreview = () => {
            // Update Name
            document.getElementById('preview-name').innerText =
                document.getElementById('CarriageClass_Name').value || 'New Class';

            // Update Percentage
            const pct = document.getElementById('CarriageClass_IncreasePercentage').value || '0';
            document.getElementById('preview-percentage').innerText = `+${pct}% Fee`;

            // Update Icons color based on selection
            const toggleIcon = (selectId, iconId) => {
                const val = document.getElementById(selectId).value;
                const icon = document.getElementById(iconId);
                if(val === "true") {
                    icon.classList.remove('text-300');
                    icon.classList.add('text-success');
                } else {
                    icon.classList.add('text-300');
                    icon.classList.remove('text-success');
                }
            };

            toggleIcon('CarriageClass_Hasfood', 'icon-food');
            toggleIcon('CarriageClass_HasWifi', 'icon-wifi');
            toggleIcon('CarriageClass_HasAirConditioning', 'icon-ac');
        };

        // Listeners
        document.getElementById('CarriageClass_Name').addEventListener('input', updatePreview);
        document.getElementById('CarriageClass_IncreasePercentage').addEventListener('input', updatePreview);
        document.getElementById('CarriageClass_Hasfood').addEventListener('change', updatePreview);
        document.getElementById('CarriageClass_HasWifi').addEventListener('change', updatePreview);
        document.getElementById('CarriageClass_HasAirConditioning').addEventListener('change', updatePreview);
    </script>
}