@using TrainTicketsProject.Models.ViewsModel.CarriageClassVMs
@model CarriageClassVM

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row flex-between-center g-3">
                <div class="col-md">
                    <h5 class="mb-2 mb-md-0 d-flex align-items-center">
                        <span class="fas fa-tags me-2 text-primary"></span>
                        <span>Carriage Classes Management</span>
                    </h5>
                </div>
                <div class="col-auto">
                    <a class="btn btn-falcon-primary btn-sm" href="/Admin/CarriageClass/Create">
                        <span class="fas fa-plus me-1"></span> New Class
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow-none border">
        <div class="card-header bg-light">
            <form method="get" asp-action="Index">
                <div class="row align-items-center justify-content-between g-2">
                    <div class="col-sm-auto d-flex align-items-center">
                        <!-- Reset All -->
                        <a asp-action="Index" class="btn btn-falcon-default btn-sm me-2 text-danger" title="Clear Search">
                            <span class="fas fa-eraser"></span>
                        </a>
                        <select class="form-select form-select-sm" id="customLength" style="width: auto;">
                            <option value="10">10 entries</option>
                            <option value="25">25 entries</option>
                        </select>
                    </div>
                    <div class="col-sm-auto">
                        <div class="d-flex align-items-center gap-2">
                            <!-- Search Input -->
                            <div class="search-box" style="min-width: 250px;">
                                <input class="form-control form-control-sm search-input"
                                       type="search" name="ClassName"
                                       placeholder="Search by class name..."
                                       value="@Context.Request.Query["ClassName"]" />
                                <span class="fas fa-search search-box-icon"></span>
                            </div>
                            <button type="submit" class="btn btn-falcon-primary btn-sm">Filter</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive scrollbar">
                <table id="classTable" class="table table-sm table-striped fs--1 mb-0 overflow-hidden">
                    <thead class="bg-200 text-900">
                        <tr>
                            <th class="sort">ID</th>
                            <th class="sort">Class Name</th>
                            <th class="sort text-center">Price Markup</th>
                            <th class="sort text-center">Amenities</th>
                            <th class="sort text-center">Total Carriages</th>
                            <th class="text-end px-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="list">
                        @foreach (var item in Model.CarriagesClasses)
                        {
                            <tr>
                                <td class="align-middle text-primary fw-semi-bold">#@item.Id</td>
                                <td class="align-middle fw-bold text-900">@item.Name</td>
                                <td class="align-middle text-center">
                                    <span class="badge badge-soft-primary text-dark">+@item.IncreasePercentage%</span>
                                </td>
                                <td class="align-middle text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <span class="fas fa-utensils @(item.Hasfood ? "text-success" : "text-300")" title="Food Service"></span>
                                        <span class="fas fa-wifi @(item.HasWifi ? "text-success" : "text-300")" title="WiFi Availability"></span>
                                        <span class="fas fa-snowflake @(item.HasAirConditioning ? "text-success" : "text-300")" title="Air Conditioning"></span>
                                    </div>
                                </td>
                                <td class="align-middle text-center">
                                    <span class="badge rounded-pill bg-200 text-dark">@item.Carriages.Count() Units</span>
                                </td>
                                <td class="align-middle text-end px-3">
                                    <div class="dropdown font-sans-serif position-static">
                                        <button class="btn btn-link text-600 btn-sm dropdown-toggle btn-reveal" type="button" data-bs-toggle="dropdown">
                                            <span class="fas fa-ellipsis-h fs--1"></span>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-end border py-2">
                                            <a class="dropdown-item" href="/Admin/CarriageClass/Edit/@item.Id">Edit Details</a>
                                            <div class="dropdown-divider"></div>
                                            <a class="dropdown-item text-danger btn-delete"
                                               href="javascript:void(0)"
                                               data-id="@item.Id"
                                               data-url="@Url.Action("Delete", "CarriageClass", new { area = "Admin" })">Delete Class</a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination Footer -->
        <div class="card-footer bg-light py-2">
            <div class="row align-items-center justify-content-between">
                <div class="col-auto">
                    <p class="mb-0 fs--1 fw-semi-bold text-600">
                        Page @Model.CurrentPage of @Model.TotalPages
                    </p>
                </div>
                <div class="col-auto">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="/Admin/CarriageClass/Index?page=@(Model.CurrentPage - 1)&ClassName=@Context.Request.Query["ClassName"]">
                                <span class="fas fa-chevron-left"></span>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="/Admin/CarriageClass/Index?page=@i&ClassName=@Context.Request.Query["ClassName"]">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="/Admin/CarriageClass/Index?page=@(Model.CurrentPage + 1)&ClassName=@Context.Request.Query["ClassName"]">
                                <span class="fas fa-chevron-right"></span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ToastreScriptPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // SweetAlert Delete Logic
            $('.btn-delete').on('click', function () {
                const id = $(this).data('id');
                const url = $(this).data('url');

                Swal.fire({
                    title: 'Are you sure?',
                    text: "All associations with this class might be affected!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Yes, delete class!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.createElement('form');
                        form.method = 'post';
                        form.action = `${url}/${id}`;
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });
        });
    </script>
}