@using TrainTicketsProject.Models.ViewsModel.CarriageClassVMs
@model CarriageClassEditVM

<main>
    <div class="container-fluid py-4">
        <!-- Breadcrumb & Title Section -->
        <div class="row align-items-center justify-content-between g-3 mb-4">
            <div class="col-auto">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/admin/home">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-controller="CarriageClass" asp-action="Index">Carriage Classes</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit Class</li>
                    </ol>
                </nav>
                <h3 class="fw-bold text-900 mt-2">✏️ Edit Carriage Class: <span class="text-primary">@Model.CarriageClass.Name</span></h3>
            </div>
            <div class="col-auto">
                <a asp-controller="CarriageClass" asp-action="Index" class="btn btn-falcon-default btn-sm">
                    <span class="fas fa-chevron-left me-1"></span> Back to List
                </a>
            </div>
        </div>

        <form method="post" asp-area="Admin" asp-controller="CarriageClass" asp-action="Edit" enctype="multipart/form-data">
            <div class="row g-3">
                <!-- Left Side: Main Configuration (8/12) -->
                <div class="col-lg-8">
                    <div class="card shadow-none border mb-3">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Class Specifications</h5>
                        </div>
                        <div class="card-body">
                            <input type="hidden" asp-for="CarriageClass.Id" />

                            <div class="row g-3">
                                <!-- Class Name -->
                                <div class="col-md-6">
                                    <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.Name">Class Name</label>
                                    <input type="text" class="form-control shadow-none" placeholder="e.g. First Class" asp-for="CarriageClass.Name">
                                    <span class="text-danger fs--1" asp-validation-for="CarriageClass.Name"></span>
                                </div>

                                <!-- Increase Percentage -->
                                <div class="col-md-6">
                                    <label class="form-label text-900 fw-semi-bold" asp-for="CarriageClass.IncreasePercentage">Price Increase (%)</label>
                                    <div class="input-group">
                                        <input type="number" class="form-control shadow-none" placeholder="0" asp-for="CarriageClass.IncreasePercentage">
                                        <span class="input-group-text bg-200">%</span>
                                    </div>
                                    <span class="text-danger fs--1" asp-validation-for="CarriageClass.IncreasePercentage"></span>
                                </div>

                                <hr class="my-4 text-300" />
                                <h6 class="fw-bold text-primary mb-0">Amenities & Features</h6>

                                <!-- Amenities Switches -->
                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="foodSwitch" asp-for="CarriageClass.Hasfood">
                                        <label class="form-check-label fw-semi-bold text-900" for="foodSwitch">Meal Service</label>
                                    </div>
                                    <div class="form-text fs--2 text-muted">Include food/drinks in ticket.</div>
                                </div>

                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="wifiSwitch" asp-for="CarriageClass.HasWifi">
                                        <label class="form-check-label fw-semi-bold text-900" for="wifiSwitch">Wi-Fi Access</label>
                                    </div>
                                    <div class="form-text fs--2 text-muted">High-speed internet on board.</div>
                                </div>

                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="acSwitch" asp-for="CarriageClass.HasAirConditioning">
                                        <label class="form-check-label fw-semi-bold text-900" for="acSwitch">Air Conditioning</label>
                                    </div>
                                    <div class="form-text fs--2 text-muted">Climate controlled environment.</div>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="col-12 mt-4 border-top pt-3 d-flex justify-content-between">
                                <a asp-controller="CarriageClass" asp-action="Index" class="btn btn-falcon-default btn-sm">
                                    <span class="fas fa-times me-1"></span> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary px-5">
                                    <span class="fas fa-save me-1"></span> Update Class
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Side: Meta Info Card (4/12) -->
                <div class="col-lg-4">
                    <div class="card shadow-none border bg-light h-100">
                        <div class="card-header bg-transparent border-bottom">
                            <h6 class="mb-0 d-flex align-items-center">
                                <span class="fas fa-info-circle me-2 text-primary"></span>Record Information
                            </h6>
                        </div>
                        <div class="card-body fs--1">
                            <div class="mb-3">
                                <label class="text-600 fw-bold mb-1">Created At</label>
                                <div class="p-2 bg-white rounded border text-900">@Model.CreatedAtInfo</div>
                            </div>
                            <div class="mb-3">
                                <label class="text-600 fw-bold mb-1">Created By</label>
                                <div class="p-2 bg-white rounded border text-900 d-flex align-items-center">
                                    <span class="fas fa-user-plus fs--2 me-2 text-400"></span> @Model.createdUserName
                                </div>
                            </div>

                            <hr class="text-300" />

                            <div class="mb-3">
                                <label class="text-600 fw-bold mb-1 text-primary">Last Update</label>
                                <div class="p-2 bg-white rounded border text-900">@Model.UpdatedAtInfo</div>
                            </div>
                            <div class="mb-0">
                                <label class="text-600 fw-bold mb-1">Updated By</label>
                                <div class="p-2 bg-white rounded border text-900 d-flex align-items-center">
                                    <span class="fas fa-user-edit fs--2 me-2 text-400"></span> @(Model.updatedUserName ?? "N/A")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_ToastreScriptPartial" />
}