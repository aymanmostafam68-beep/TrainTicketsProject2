@using TrainTicketsProject.Models.ViewsModel.CarriageVMs
@model CarriageEditVM

<main>
    <div class="container-fluid py-4">
        <!-- Breadcrumb & Title Section -->
        <div class="row align-items-center justify-content-between g-3 mb-4">
            <div class="col-auto">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/admin/home">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Carriage" asp-action="Index">Carriages List</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit Carriage</li>
                    </ol>
                </nav>
                <h3 class="fw-bold text-900 mt-2">✏️ Edit Carriage: <span class="text-primary">@Model.Carriage.CarriageName</span></h3>
            </div>
            <div class="col-auto">
                <a asp-area="Admin" asp-controller="Carriage" asp-action="Index" class="btn btn-falcon-default btn-sm">
                    <span class="fas fa-chevron-left me-1"></span> Back to List
                </a>
            </div>
        </div>

        <div class="row g-3">
            <!-- Left Side: Main Form (8/12)[cite: 3] -->
            <div class="col-lg-8">
                <div class="card shadow-none border mb-3">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Carriage Specifications</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-area="Admin" asp-controller="Carriage" asp-action="Edit" enctype="multipart/form-data" class="row g-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Carriage.CarriageId" />

                            <!-- Carriage Name -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="Carriage.CarriageName">Carriage Name/Code</label>
                                <input type="text" class="form-control shadow-none" placeholder="e.g. C-101" asp-for="Carriage.CarriageName">
                                <span class="text-danger fs--1" asp-validation-for="Carriage.CarriageName"></span>
                            </div>

                            <!-- Capacity -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="Carriage.Capacity">Passenger Capacity</label>
                                <input type="number" class="form-control shadow-none" placeholder="Enter seat count" asp-for="Carriage.Capacity">
                                <span class="text-danger fs--1" asp-validation-for="Carriage.Capacity"></span>
                            </div>

                            <!-- Train Assignment -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="Carriage.TrainId">Assigned Train</label>
                                <select class="form-select shadow-none js-choice" asp-for="Carriage.TrainId" asp-items="Model.TrainList">
                                    <option value="">-- Select Train --</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="Carriage.TrainId"></span>
                            </div>

                            <!-- Class Assignment -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold" asp-for="Carriage.TrainClassId">Travel Class</label>
                                <select class="form-select shadow-none js-choice" asp-for="Carriage.TrainClassId" asp-items="Model.ClassList">
                                    <option value="">-- Select Class --</option>
                                </select>
                                <span class="text-danger fs--1" asp-validation-for="Carriage.TrainClassId"></span>
                            </div>

                            <!-- Status -->
                            <div class="col-md-6">
                                <label class="form-label text-900 fw-semi-bold">Maintenance Status</label>
                                <select class="form-select shadow-none" asp-for="Carriage.IsActive">
                                    <option value="true">Active (In Service)</option>
                                    <option value="false">Inactive (Under Maintenance)</option>
                                </select>
                            </div>

                            <!-- Submit Actions[cite: 3] -->
                            <div class="col-12 mt-4 border-top pt-3 d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-falcon-default btn-sm">
                                    <span class="fas fa-times me-1"></span> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary px-5">
                                    <span class="fas fa-save me-1"></span> Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Side: Audit Info (4/12)[cite: 3] -->
            <div class="col-lg-4">
                <div class="card shadow-none border bg-light h-100">
                    <div class="card-header bg-transparent border-bottom">
                        <h6 class="mb-0 d-flex align-items-center">
                            <span class="fas fa-history me-2 text-primary"></span>Record History
                        </h6>
                    </div>
                    <div class="card-body fs--1">
                        <div class="mb-3">
                            <label class="text-600 fw-bold mb-1">Created At</label>
                            <div class="p-2 bg-white rounded border">
                                <span class="text-900">@Model.CreatedAtInfo</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="text-600 fw-bold mb-1">Created By</label>
                            <div class="p-2 bg-white rounded border">
                                <span class="fas fa-user fs--2 me-2 text-400"></span>
                                <span class="text-900 text-capitalize">@Model.createdUserName</span>
                            </div>
                        </div>

                        <hr class="text-300" />

                        <div class="mb-3">
                            <label class="text-600 fw-bold mb-1 text-primary text-uppercase">Last Modification</label>
                            <div class="p-2 bg-white rounded border">
                                <span class="text-900">@Model.UpdatedAtInfo</span>
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="text-600 fw-bold mb-1">Updated By</label>
                            <div class="p-2 bg-white rounded border">
                                <span class="fas fa-user-edit fs--2 me-2 text-400"></span>
                                <span class="text-900 text-capitalize">@(Model.updatedUserName ?? "N/A")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ToastreScriptPartial" />
    <partial name="_ValidationScriptsPartial" />
}