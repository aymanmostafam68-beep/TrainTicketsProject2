@model ProfileMixedEditVM
<!DOCTYPE html>
<html data-bs-theme="dark" lang="en-US" dir="ltr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <!-- ===============================================-->
    <!--    Document Title-->
    <!-- ===============================================-->
    <title>Falcon | Dashboard &amp; Web App Template</title>


    <!-- ===============================================-->
    <!--    Favicons-->
    <!-- ===============================================-->
    <link rel="apple-touch-icon" sizes="180x180" href="../../Identity/assets/img/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="../../Identity/assets/img/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="../../Identity/assets/img/favicons/favicon-16x16.png">
    <link rel="shortcut icon" type="image/x-icon" href="../../Identity/assets/img/favicons/favicon.ico">
    <link rel="manifest" href="../../Identity/assets/img/favicons/manifest.json">
    <meta name="msapplication-TileImage" content="../../Identity/assets/img/favicons/mstile-150x150.png">
    <meta name="theme-color" content="#ffffff">
    <script src="../../Identity/assets/js/config.js"></script>
    <script src="~/vendors/simplebar/simplebar.min.js"></script>


    <!-- ===============================================-->
    <!--    Stylesheets-->
    <!-- ===============================================-->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,600,700%7cPoppins:300,400,500,600,700,800,900&amp;display=swap" rel="stylesheet">
    <link href="~/vendors/simplebar/simplebar.min.css" rel="stylesheet">
    <link href="~/assets/css/theme-rtl.css" rel="stylesheet" id="style-rtl">
    <link href="~/assets/css/theme.css" rel="stylesheet" id="style-default">
    <link href="~/assets/css/user-rtl.css" rel="stylesheet" id="user-style-rtl">
    <link href="~/assets/css/user.css" rel="stylesheet" id="user-style-default">
    <script>
        var isRTL = JSON.parse(localStorage.getItem('isRTL'));
        if (isRTL) {
          var linkDefault = document.getElementById('style-default');
          var userLinkDefault = document.getElementById('user-style-default');
          linkDefault.setAttribute('disabled', true);
          userLinkDefault.setAttribute('disabled', true);
          document.querySelector('html').setAttribute('dir', 'rtl');
        } else {
          var linkRTL = document.getElementById('style-rtl');
          var userLinkRTL = document.getElementById('user-style-rtl');
          linkRTL.setAttribute('disabled', true);
          userLinkRTL.setAttribute('disabled', true);
        }
    </script>
</head>





<div class="container mt-3">
    <!-- Profile Header Section -->
    <div class="card mb-3">
        <!-- Banner Image -->
        <div class="card-header position-relative min-vh-25 mb-7">
            <div class="bg-holder rounded-3 rounded-bottom-0"
                 style="background-image:url(/Identity/assets/img/generic/4.jpg);">
            </div>
            <!--/.bg-holder-->
            <!-- Profile Picture (Positioned to overlap) -->
            <div class="avatar avatar-5xl avatar-profile">
                <img class="rounded-circle img-thumbnail shadow-sm"
                     src="/Identity/assets/img/team/2.jpg" width="200" alt="User Profile" />
            </div>
        </div>
    </div>

    <!-- Profile Settings Form -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Profile Settings</h5>
        </div>
        <div class="card-body bg-dark">
            <form asp-action="UpdateProfile" method="post">
                <div class="row g-3">
                    <input type="hidden" name="Id" value="@Model.profileEditVM.Id" />

                    <!-- First Name -->
                    <div class="col-lg-6">
                        <label asp-for="profileEditVM.FirstName" class="form-label" for="first-name">First Name</label>
                        <input asp-for="profileEditVM.FirstName" class="form-control" id="first-name" type="text" />
						<span asp-validation-for="profileEditVM.FirstName" class="text-danger"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="col-lg-6">
                        <label asp-for="profileEditVM.LastName" class="form-label" for="last-name">Last Name</label>
                        <input asp-for="profileEditVM.LastName" class="form-control" id="last-name" type="text" />
						<span asp-validation-for="profileEditVM.LastName" class="text-danger"></span>
                    </div>


                    <!-- Phone -->
                    <div class="col-lg-6">
                        <label asp-for="profileEditVM.PhoneNumber" class="form-label" for="phone">Phone</label>
                        <input asp-for="profileEditVM.PhoneNumber" inputmode="" class="form-control" id="phone" type="text" />
                        <span asp-validation-for="profileEditVM.PhoneNumber" class="text-danger"></span>
                    </div>


                    <div class="col-6">
                        <label asp-for="profileEditVM.NationalId" class="form-label" for="NationalID">National ID</label>
                        <input asp-for="profileEditVM.NationalId" class="form-control" id="NationalID" type="text" />
                        <span asp-validation-for="profileEditVM.NationalId" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-lg-6">
                        <label asp-for="profileEditVM.Email" class="form-label" for="email">Email</label>
                        <input asp-for="profileEditVM.Email" class="form-control" id="email" type="email" />
						<span asp-validation-for="profileEditVM.Email" class="text-danger"></span>
                    </div>

                

                      <!-- Address -->
                    <div class="col-lg-6">
                        <label asp-for="profileEditVM.Address" class="form-label" for="address">Address</label>
                        <input asp-for="profileEditVM.Address" class="form-control" id="address" type="text" />
						<span asp-validation-for="profileEditVM.Address" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            Update Profile
                        </button>
                    </div>
                </div>



            </form>
                    <form asp-action="ResetPassword" method="post">
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                <input type="hidden" name="Id" value="@Model.identityEditVM.Id" />


                    <!-- Password -->
                    <div class="col-lg-6">
                    <label asp-for="identityEditVM.NewPassword" class="form-label" for="NewPassword">Password</label>
                    <input asp-for="identityEditVM.NewPassword" class="form-control" id="NewPassword" type="password" />
                        <span asp-validation-for="identityEditVM.NewPassword" class="text-danger"></span>
                    </div>



                    <!-- Confirm Password -->
                    <div class="col-lg-6">
                        <label asp-for="identityEditVM.ConfirmPassword" class="form-label" for="ConfirmPassword">Confirm Password</label>
                        <input asp-for="identityEditVM.ConfirmPassword" class="form-control" id="ConfirmPassword" type="password" />
                        <span asp-validation-for="identityEditVM.ConfirmPassword" class="text-danger"></span>
                    </div>

                <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="togglePassword">
                    <label class="form-check-label" for="togglePassword">Show Password</label>
                </div>

                        <div class="col-lg-6 d-flex justify-content-end align-self-end">
                            <button type="submit" class="btn btn-danger btn-sm">
                                Change Password
                            </button>
                        </div>

                    </form>
                

             
        </div>
    </div>
</div>


@section Scripts
{

    <partial name="_ToastreScriptPartial" />
    <partial name="_ValidationScriptsPartial" />

}
<script>
    const passwordInput = document.querySelector('#ConfirmPassword');

    const toggleCheckbox = document.querySelector('#togglePassword');

    toggleCheckbox.addEventListener('change', function() {
        // Toggle the type attribute
        const type = this.checked ? 'text' : 'password';
        passwordInput.setAttribute('type', type);
    });
</script>
